---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: string | ImageMetadata;
  alt: string;
  width?: number;
  height?: number;
  className?: string;
  loading?: 'eager' | 'lazy';
  decoding?: 'async' | 'sync' | 'auto';
}

const { 
  src, 
  alt, 
  width = 800, 
  height,
  className = '', 
  loading = 'lazy',
  decoding = 'async'
} = Astro.props;

// 判断是否为本地图片
const isLocalImage = typeof src === 'object' || (typeof src === 'string' && src.startsWith('/'));
---

{
  isLocalImage && typeof src === 'object' ? (
    <Image 
      src={src}
      alt={alt}
      width={width}
      height={height}
      class={className}
      loading={loading}
      decoding={decoding}
      format="avif"
      quality={80}
    />
  ) : (
    <img 
      src={typeof src === 'string' ? src : ''}
      alt={alt}
      width={width}
      height={height}
      class={className}
      loading={loading}
      decoding={decoding}
    />
  )
}
